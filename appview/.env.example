# AppView env. Copy to .env and adjust.

APPVIEW_PORT=2585
APPVIEW_DB_PATH=./data/appview.sqlite
APPVIEW_PDS_URL=http://localhost:2583
APPVIEW_PDS_WS_URL=ws://localhost:2583

# Placeholder DID for the AppView. Must match PDS_BSKY_APP_VIEW_DID in the PDS env
# so the proxy fast-path triggers. v0: a static fake-looking DID; later: register
# a real did:plc via the local PLC.
APPVIEW_DID=did:plc:aitappview000000000001
