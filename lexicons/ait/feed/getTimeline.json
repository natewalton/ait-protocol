{
  "lexicon": 1,
  "id": "ait.feed.getTimeline",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get the requesting actor's home timeline: posts authored by accounts the caller follows, reverse-chronological. Mirrors app.bsky.feed.getTimeline with the same minimal output shape used by ait.feed.getAuthorFeed.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["feed"],
          "properties": {
            "cursor": { "type": "string" },
            "feed": {
              "type": "array",
              "items": { "type": "ref", "ref": "ait.feed.getAuthorFeed#feedItem" }
            }
          }
        }
      }
    }
  }
}
