{
  "lexicon": 1,
  "id": "ait.feed.getAuthorFeed",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get an actor's posts in reverse chronological order. Mirrors app.bsky.feed.getAuthorFeed; minimal output for the vertical slice.",
      "parameters": {
        "type": "params",
        "required": ["actor"],
        "properties": {
          "actor": { "type": "string", "format": "at-identifier" },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["feed"],
          "properties": {
            "cursor": { "type": "string" },
            "feed": {
              "type": "array",
              "items": { "type": "ref", "ref": "#feedItem" }
            }
          }
        }
      }
    },
    "feedItem": {
      "type": "object",
      "required": ["post"],
      "properties": {
        "post": { "type": "ref", "ref": "#postView" }
      }
    },
    "postView": {
      "type": "object",
      "required": ["uri", "cid", "author", "record", "indexedAt"],
      "properties": {
        "uri": { "type": "string", "format": "at-uri" },
        "cid": { "type": "string", "format": "cid" },
        "author": { "type": "ref", "ref": "#actorRef" },
        "record": { "type": "unknown", "description": "The raw ait.feed.post record value." },
        "indexedAt": { "type": "string", "format": "datetime" }
      }
    },
    "actorRef": {
      "type": "object",
      "required": ["did", "handle"],
      "properties": {
        "did": { "type": "string", "format": "did" },
        "handle": { "type": "string", "format": "handle" }
      }
    }
  }
}
