# PLC directory env. Copy to .env (which is gitignored) and adjust.

# Postgres connection. The database (default name: plc_directory) must exist before starting.
DATABASE_URL=postgres://USER@localhost:5432/plc_directory

# HTTP port. The PLC server defaults to 2582 if unset.
PORT=2582

# Admin secret for privileged operations. Generate with: openssl rand -hex 32
ADMIN_SECRET=
